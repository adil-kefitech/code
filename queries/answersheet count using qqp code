SELECT
    bm.id                  AS bundle_id,
    bm.bundle_code,
    bm.qp_code,
    cs.id                  AS camp_schedule_id,
    csc.exam_schedule_id
FROM uok.pgd_bund_mstr bm
JOIN uok.pgd_bndl_camp          bc  ON bc.bundle_id       = bm.id
JOIN uok.pgd_camp_schedule      cs  ON cs.sub_camp_id     = bc.sub_camp_id
LEFT JOIN uok.pgd_camp_schedule_course csc ON csc.camp_schedule_id = cs.id
WHERE bm.id = 103709 



